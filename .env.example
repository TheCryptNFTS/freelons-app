# Freelons admin secret — used to trigger override windows
FREELONS_ADMIN_SECRET=change-me-to-something-strong

# Auth secret for SIWE session cookies — MUST be strong in prod
FREELONS_AUTH_SECRET=change-me-to-something-very-strong

# WalletConnect project ID (free at https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=your-wc-project-id

# Optional: custom RPC for on-chain ownerOf calls (Alchemy/QuickNode)
FREELONS_RPC_URL=https://eth-mainnet.public.blastapi.io

# Disable demo signal traffic in production
# FREELONS_DEMO=off

# --- THE ORACLE LEDGER (Edge integration) ---
# Supabase (the Oracle Ledger persists here so it survives serverless). The
# Vercel↔Supabase integration usually injects these already. SERVICE ROLE key is
# server-only — never expose it. URL: https://zrnslxmmioherpikxmsf.supabase.co
# SUPABASE_URL=https://zrnslxmmioherpikxmsf.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   (Supabase dashboard → Settings → API)
# Edge trading agent read API (server-side only; token never reaches the browser).
# If unset, the Oracle Ledger runs on a fixture so it's fully demoable without Edge.
# EDGE_API_URL=https://your-edge-host
# EDGE_READ_TOKEN=your-edge-read-token
# Allow unauthenticated ENS/"demo" handles to play (local/testing ONLY).
# Leave UNSET in production so every HEX/rating write requires SIWE + ownerOf.
# ORACLE_ALLOW_DEMO=1
# HEX economy (non-cashable points). Defaults shown.
# ORACLE_HEX_START=1000
# ORACLE_HEX_DAILY=100
# ORACLE_HEX_MIN=10
# ORACLE_HEX_MAX=500
